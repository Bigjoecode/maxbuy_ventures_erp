# Database (PostgreSQL recommended for production; SQLite works for local dev)
DATABASE_URL="postgresql://user:password@localhost:5432/maxbuy_erp?schema=public"

# Auth
JWT_SECRET="replace-with-a-long-random-secret-string"
JWT_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_NAME="Maxbuy Ventures"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WhatsApp / SMS integration (e.g. Twilio, Termii)
WHATSAPP_API_KEY=""
SMS_API_KEY=""

# Cloud backup (e.g. AWS S3 / Cloudinary)
CLOUD_STORAGE_BUCKET=""
CLOUD_STORAGE_KEY=""
CLOUD_STORAGE_SECRET=""

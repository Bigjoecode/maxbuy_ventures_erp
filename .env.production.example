# Maxbuy Ventures — production environment.
# Copy to .env on the server and fill in real values. NEVER commit the real .env.

# --- Database (used by docker-compose to create the Postgres container) ---
POSTGRES_USER=maxbuy
POSTGRES_PASSWORD=change-me-to-a-long-random-password
POSTGRES_DB=maxbuy_erp

# DATABASE_URL is assembled from the POSTGRES_* values by docker-compose for the
# app service. If you run the app outside compose, set it explicitly:
# DATABASE_URL=postgresql://maxbuy:password@db:5432/maxbuy_erp?schema=public

# --- Auth (REQUIRED — app refuses to start in production without a strong secret) ---
JWT_SECRET=generate-with-openssl-rand-base64-48
JWT_EXPIRES_IN=7d

# --- App ---
NEXT_PUBLIC_APP_NAME=Maxbuy Ventures
NEXT_PUBLIC_APP_URL=https://maxbuy.example.com

# --- SMS / OTP provider (for password reset) ---
SMS_API_KEY=

# --- Backups (used by scripts/backup.sh) ---
BACKUP_GPG_RECIPIENT=
BACKUP_S3_BUCKET=
BACKUP_RETENTION_DAYS=30

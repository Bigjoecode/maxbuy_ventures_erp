{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Maxbuy Ventures",
  "version": "1.0.0",
  "identifier": "com.maxbuy.erp",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "title": "Maxbuy Ventures",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "url": "https://maxbuy-ventures-erp.vercel.app"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
